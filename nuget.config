<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github" value="https://nuget.pkg.github.com/danielgsmith/index.json" />
  </packageSources>
  <!--
    Credentials are not committed to the repo.
    CI uses NUGET_AUTH_TOKEN via the workflow env.
    For local pushes, run the command documented in README.md.
  -->
</configuration>
